# Kontaktní formulář — odesílání přes Resend (https://resend.com)
# Zkopíruj do .env.local a vyplň.

# Povinné: API klíč z Resend
RESEND_API_KEY=

# Povinné: kam mají chodit poptávky (tvůj e-mail)
CONTACT_TO_EMAIL=

# Volitelné: odesílatel. Bez ověřené domény nech prázdné —
# použije se onboarding@resend.dev (Resend pak doručí jen na CONTACT_TO_EMAIL).
# S vlastní ověřenou doménou např.: "Web robinpetr.cz <formular@robinpetr.cz>"
CONTACT_FROM_EMAIL=

# Cloudflare Web Analytics (bez cookies, bez lišty) — volitelné.
# Token: Cloudflare dashboard → Web Analytics → Add a site → beacon token.
# Build-time (NEXT_PUBLIC_*), musí být dostupné při buildu/deploy.
NEXT_PUBLIC_CF_BEACON_TOKEN=
