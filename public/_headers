# Cache statiky (Cloudflare Workers Static Assets respektuje _headers).

# Hashované Next.js assety — neměnné, dlouhá cache
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable

# Obrázky v /public — týdenní cache
/*.png
  Cache-Control: public, max-age=604800
/*.svg
  Cache-Control: public, max-age=604800
/*.jpg
  Cache-Control: public, max-age=604800
/*.webp
  Cache-Control: public, max-age=604800
